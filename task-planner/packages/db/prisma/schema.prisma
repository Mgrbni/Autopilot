generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  Inbox
  ClarifyingNeeded
  Researching
  ReadyToSchedule
  Scheduled
  WaitingOnUser
  WaitingOnExternal
  InProgress
  Blocked
  Done
  Cancelled
}

enum TaskEventType {
  task_created
  field_extracted
  clarification_requested
  clarification_answered
  research_requested
  research_result_added
  research_approved
  subtask_created
  plan_proposed
  plan_approved
  progress_logged
  blocker_detected
  blocker_resolved
  task_done
  task_cancelled
}

enum TaskEventActor {
  user
  system
  assistant
  research
}

model Task {
  id                     String    @id @default(cuid())
  title                  String
  rawInput               String
  taskType               String?
  strategicArea          String?
  status                 TaskStatus @default(Inbox)
  priority               Int?
  deadline               DateTime?
  hardDeadline           Boolean   @default(false)
  estimatedDurationMin   Int?
  needsPhysicalPresence  Boolean?
  needsResearch          Boolean?
  needsPrep              Boolean?
  prepNotes              String?
  institutionId          String?
  locationId             String?
  appointmentRequired    Boolean?
  requiredDocuments      String[]
  transportModePreferred String?
  estimatedCostTl        Float?
  proposedStart          DateTime?
  proposedEnd            DateTime?
  approvedStart          DateTime?
  approvedEnd            DateTime?
  followupDue            DateTime?
  missingFields          String[]
  aiSummary              String?
  userApprovedPlan       Boolean   @default(false)
  parentTaskId           String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  events            TaskEvent[]
  researchSnapshots ResearchSnapshot[]
  scheduleItems     ScheduleItem[]
}

model TaskEvent {
  id        String         @id @default(cuid())
  taskId    String
  eventType TaskEventType
  actor     TaskEventActor
  payload   Json
  summary   String
  createdAt DateTime       @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}

model UserProfile {
  id                        String @id @default(cuid())
  homeBase                  String?
  workScheduleJson          Json
  preferredTransportOrder   String[]
  morningTransportRule      String?
  acceptableTaxiThresholdTl Float?
  defaultTravelBufferMin    Int    @default(20)
  workdayErrandPolicy       String?
  knownDocuments            String[]
  budgetSensitivity         String?
  allowBeforeWork           Boolean @default(true)
  allowAfterWork            Boolean @default(true)
  allowSundayErrands        Boolean @default(false)
  timezone                  String  @default("UTC")
  updatedAt                 DateTime @updatedAt
  createdAt                 DateTime @default(now())
}

model Institution {
  id                         String   @id @default(cuid())
  name                       String   @unique
  address                    String?
  district                   String?
  city                       String?
  officialHours              String?
  appointmentRequiredDefault Boolean?
  defaultRequiredDocuments   String[]
  source                     String?
  lastVerifiedAt             DateTime?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model ResearchSnapshot {
  id             String   @id @default(cuid())
  taskId         String
  queryType      String
  queryText      String
  resultSummary  String
  structuredData Json
  sourceLinks    String[]
  confidence     Float
  approvedByUser Boolean  @default(false)
  createdAt      DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}

model ScheduleItem {
  id              String   @id @default(cuid())
  taskId          String
  start           DateTime
  end             DateTime
  travelMode      String?
  travelStart     DateTime?
  estimatedCostTl Float?
  approved        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, start])
}
