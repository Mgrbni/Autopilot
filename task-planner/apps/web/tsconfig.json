{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": false,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@task-planner/ai": ["../../packages/ai/index.ts"],
      "@task-planner/ai/*": ["../../packages/ai/*"],
      "@task-planner/notion": ["../../packages/notion/index.ts"],
      "@task-planner/notion/*": ["../../packages/notion/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
